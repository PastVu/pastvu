.adminRegionCheck(data-bind="with: repository[M!M]")
    h4(data-bind="text: $root.i18n('Find regions by point')")
    .topinfo
        span.infotxt(data-bind="text: $root.i18n('Click on the map or enter comma-separated coordinates:')")
        .inputGeoWrap
            .input-group
                input.form-control.input-sm.inputGeo(type="text", data-bind="event: {keyup: inputEnter}, attr: {placeholder: $root.i18n('Latitude, longitude')}")
                span.input-group-addon(data-bind="click: inputGeo")
                    span.glyphicon.glyphicon-screenshot
        .extlnk
            span.infotxt(data-bind="text: $root.i18n('Link to the displayed point:')")
            input.form-control.input-sm.inputLink(type="text", onclick="this.select();", readonly, data-bind="value: location.host + location.pathname + link()")
    .map(data-bind="style: {height: mh()}")