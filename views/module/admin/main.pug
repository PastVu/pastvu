.mainAdmin(data-bind="with: repository[M!M]")
    h6(data-bind="text: $root.i18n('Current connections')")
    div
        span.stateRate
            .rate(data-bind="text: onlines.users()")
            | /
            .rate(data-bind="text: (onlines.all() - onlines.users())")
            | /
            .rate(data-bind="text: onlines.all()")
        span.stateDesc(data-bind="text: $root.i18n('Visitors authenticated/anonymous/total')")
    div
        span.stateRate
            .rate(data-bind="text: onlines.sessUC()")
            | /
            .rate(data-bind="text: onlines.sessAC()")
            | /
            .rate(data-bind="text: (onlines.sessUC() + onlines.sessAC())")
        span.stateDesc(data-bind="text: $root.i18n('Active sessions authenticated/anonymous/total. With zero connections: [{{uz}}/{{az}}]. Without connections: [{{un}}/{{an}}].', {uz: onlines.sessUZC(), az: onlines.sessAZC(), un: onlines.sessUNC(), an: onlines.sessANC()})")

    div
        span.stateRate
            .rate(data-bind="text: onlines.sessWCUC()")
            | /
            .rate(data-bind="text: onlines.sessWCAC()")
            | /
            .rate(data-bind="text: (onlines.sessWCUC() + onlines.sessWCAC())")
        span.stateDesc(data-bind="text: $root.i18n('Pending sessions authenticated/anonymous/total')")
    div
        span.stateRate
            .rate(data-bind="text: onlines.sockUC()")
            | /
            .rate(data-bind="text: onlines.sockAC()")
            | /
            .rate(data-bind="text: (onlines.sockUC() + onlines.sockAC())")
        span.stateDesc(data-bind="text: $root.i18n('Active connections authenticated/anonymous/total')")
    div
        span.stateDesc(data-bind="text: $root.i18n('In-memory user-object hashes:') + ' '")
        span.stateRate
            | usSid:
            .rate(data-bind="text: ' '+ onlines.cusSid()")
            | , usLogin:
            .rate(data-bind="text: ' '+ onlines.cusLogin()")
            | , usId:
            .rate(data-bind="text: ' '+ onlines.cusId()")
    div
        span.stateDesc(data-bind="text: $root.i18n('In-memory session hashes:') + ' '")
        span.stateRate
            | sessConnected:
            .rate(data-bind="text: ' '+ onlines.csessConnected()")
            | , sessWaitingConnect:
            .rate(data-bind="text: ' '+ onlines.csessWaitingConnect()")
            | , sessWaitingSelect:
            .rate(data-bind="text: ' '+ onlines.csessWaitingSelect()")
    .desc
        strong(data-bind="text: $root.i18n('Active session')")
        span(data-bind="text: ' ' + $root.i18n('- one client browser with PastVu open in at least one tab. Zero-connection entries mean a closed connection did not clear the session (zero is normal). Connection-less entries mean a session was promoted to active without ever establishing a real connection (zero is normal).')")
        br
        strong(data-bind="text: $root.i18n('Pending session')")
        span(data-bind="text: ' ' + $root.i18n('- a client that completed the handshake but never established a real connection. Such sessions are dropped after 5 minutes if no connection arrives.')")
        br
        strong(data-bind="text: $root.i18n('Active connection')")
        span(data-bind="text: ' ' + $root.i18n('- each open client tab of an active session')")
        br
        br
        span(data-bind="text: $root.i18n('Each client session (browser) can have several open connections (tabs)')")
        br
        span(data-bind="text: $root.i18n('A user authenticated (signed in) in several browsers at once counts as a single user but has multiple sessions, one per open browser. That is why \"active authenticated sessions\" can exceed the authenticated-user count.')")
    br

    //ko if: headers().length
    h6(data-bind="text: $root.i18n('Headers of ACTIVE sessions without connections (if any):')")
    div(data-bind="foreach: headers")
        | -------
        .headers(data-bind="html: $data")
    br
    // /ko

    //ko if: headersWC().length
    h6(data-bind="text: $root.i18n('Headers of PENDING sessions without connections (if any):')")
    div(data-bind="foreach: headersWC")
        | -------
        .headers(data-bind="html: $data")
    // /ko