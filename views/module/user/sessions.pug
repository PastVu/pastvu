.user_sessions(data-bind="with: repository[M!M]"): .panel-group#accordion
    .panel.panel-pastvu
        .panel-heading: .panel-title: a(data-toggle="collapse", href="#sessions", data-bind="text: $root.i18n('Активные сессии')")
        .panel-collapse.collapse.in#sessions: .panel-body
            dl.dl-horizontal
                //ko if: !onlines().length && !offlines().length
                span(data-bind="text: $root.i18n('Пользователь не имеет активных сессий')")
                br
                br
                // /ko
                //ko if: onlines().length
                dt.online(data-bind="text: $root.i18n('Онлайн')")
                dd
                    //ko foreach: onlines
                    .session(data-bind="click: function () {$parent.handleShowSession($data.key, false, true)}")
                        .info
                            .versions
                                //ko if: $data.device
                                strong(data-bind="text: $data.device")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.os
                                strong(data-bind="text: $data.os")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.browser
                                span(data-bind="text: $data.browser")
                                // /ko
                                //ko if: $data.agentHistCount
                                i(data-bind="text: ' (+' + $data.agentHistCount + ')'")
                                // /ko
                            .ip
                                span(data-bind="text: 'IP: ' + $data.ip")
                                //ko if: $data.ipCount
                                i(data-bind="text: ' (+' + $data.ipCount + ')'")
                                // /ko
                            //ko if: $data.lang
                            div(data-bind="text: $root.i18n('Язык:') + ' ' + $data.lang")
                            // /ko
                            div
                                span(data-bind="text: $root.i18n('Количество открытых вкладок:') + ' '")
                                span(data-bind="text: $root.intl.num($data.sockets)")
                            div(data-bind="text: $root.i18n('Первая активность:') + ' ' + $root.intl.dateFull($data.created)")
                        //ko if: $data.isCurrent
                        div.online(style="min-width:80px; margin-right:4px; padding: 0 10px; text-align:center; font-style:italic", data-bind="text: $root.i18n('Текущая')")
                        // /ko
                        //ko if: !$data.isCurrent
                        button.btn.btn-primary(type="button", data-bind="attr: {disabled: $parent.removing.indexOf($data.key) > -1, title: $root.i18n('Уничтожить сессию')}, event:{click: $parent.handleSessionDestroy}, text: $root.i18n('Выйти')", style="min-width:80px;")
                        // /ko
                    // /ko
                // /ko

                //ko if: onlines().length && offlines().length
                br
                br
                // /ko

                //ko if: offlines().length
                dt(data-bind="text: $root.i18n('Оффлайн')")
                dd
                    //ko foreach: offlines
                    .session(data-bind="click: function () {$parent.handleShowSession($data.key)}")
                        .info
                            .versions
                                //ko if: $data.device
                                strong(data-bind="text: $data.device")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.os
                                strong(data-bind="text: $data.os")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.browser
                                span(data-bind="text: $data.browser")
                                // /ko
                                //ko if: $data.agentHistCount
                                i(data-bind="text: ' (+' + $data.agentHistCount + ')'")
                                // /ko
                            .ip
                                span(data-bind="text: 'IP: ' + $data.ip")
                                //ko if: $data.ipCount
                                i(data-bind="text: ' (+' + $data.ipCount + ')'")
                                // /ko
                            div(data-bind="text: $root.i18n('Язык:') + ' ' + $data.lang")
                            div(data-bind="text: $root.i18n('Первая активность:') + ' ' + $root.intl.dateFull($data.created)")
                            div(data-bind="text: $root.i18n('Последняя активность:') + ' ' + $root.intl.dateFull($data.stamp)")
                        button.btn.btn-primary(type="button", data-bind="attr: {disabled: $parent.removing.indexOf($data.key) > -1, title: $root.i18n('Уничтожить сессию')}, event:{click: $parent.handleSessionDestroy}, text: $root.i18n('Удалить')", style="min-width:80px;")
                    // /ko
                // /ko

                //ko if: archivedCount()
                //ko if: onlines().length || offlines().length
                br
                br
                // /ko
                dt.helpexists
                    .help.tltp-wrap
                        span.glyphicon.glyphicon-info-sign
                        .tltp.tltp-top.tltp-animate-move(data-bind="html: $root.i18n('Просмотр архивных сессий<br>доступен только администраторам')")
                    span(data-bind="text: ' ' + $root.i18n('Архивные')")
                dd
                    button.btn.btn-primary(type="button", data-bind="text: $root.i18n(archivedShow() ? 'Скрыть' : 'Показать') + (archivedShow() ? '' : ' (' + archivedCount() + ')'), event:{click: toggleArchive}, attr: {disabled: archivedFetching()}", style="min-width:80px;")
                    //ko if: archives()
                    br
                    br
                    // /ko
                    //ko foreach: archives
                    .session(data-bind="click: function () {$parent.handleShowSession($data.key, true)}")
                        .info
                            .versions
                                //ko if: $data.device
                                strong(data-bind="text: $data.device")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.os
                                strong(data-bind="text: $data.os")
                                .dotDelimeter ·
                                // /ko
                                //ko if: $data.browser
                                span(data-bind="text: $data.browser")
                                // /ko
                                //ko if: $data.agentHistCount
                                i(data-bind="text: ' (+' + $data.agentHistCount + ')'")
                                // /ko
                            .ip
                                span(data-bind="text: 'IP: ' + $data.ip")
                                //ko if: $data.ipCount
                                i(data-bind="text: ' (+' + $data.ipCount + ')'")
                                // /ko
                            //ko if: $data.lang
                            div(data-bind="text: $root.i18n('Язык:') + ' ' + $data.lang")
                            // /ko
                            div(data-bind="text: $root.i18n('Первая активность:') + ' ' + $root.intl.dateFull($data.created)")
                            div(data-bind="text: $root.i18n('Последняя активность:') + ' ' + $root.intl.dateFull($data.stamp)")
                    // /ko
                // /ko
