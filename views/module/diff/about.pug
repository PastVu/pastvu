.about(data-bind="with: repository[M!M]")
    header.line(data-bind="text: $root.i18n('PastVu — проект по сбору свидетельств прошлого. Взгляд на историю среды обитания человечества.')")
    .postrow
        div.line
            span(data-bind="text: $root.i18n('Подробная информация о проекте находится') + ' '")
            a(target="_blank", data-bind="attr: {href: getAboutUrl()}, text: $root.i18n('в базе знаний')")
            | .
        div.line
            span(data-bind="text: $root.i18n('Открытая разработка ведется') + ' '")
            a(target="_blank", href="https://github.com/PastVu", data-bind="text: $root.i18n('на GitHub')")
            span(data-bind="text: '. ' + $root.i18n('Следите за выполнением задач и принимайте участие в развитии!')")
    .postrow
        hr
        div.line
            span(data-bind="text: $root.i18n('Версия приложения') + ' '")
            span(data-bind="text: version")
            span(data-bind="text: '. ' + $root.i18n('Исходный код доступен по лицензии') + ' '")
            a(target="_blank", href="https://github.com/PastVu/pastvu/blob/master/COPYING") GNU AGPL v3.0
            | .
        div.line
            span(data-bind="text: $root.i18n('Данные по границам географических и административных регионов:') + ' © '")
            a(target="_blank", href="https://www.openstreetmap.org/copyright") OpenStreetMap contributors
            | .
    .postrow
        div.img(style="margin-top:15px;")
            img.poster(src="/img/loading/Loading1.jpg")
