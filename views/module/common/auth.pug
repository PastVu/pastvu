#auth_curtain.centering_content(data-bind="with: repository[M!M]")

    //ko if: mode()
    form.fringe(action='', autocomplete="on", method='POST', data-bind="attr: {name: mode() + 'Form'}, css: {working: working(), finish: finish()}, event: {submit: submit}")
        //ko template: {name: mode() + 'Tpl'}
        // /ko
    // /ko

    | <script id="loginTpl" type="text/html">
    .head(data-bind="text: $root.i18n('Авторизация')")
    .form-group
        dl.dl-horizontal
            dt(data-bind="text: $root.i18n('Имя пользователя:')")
            dd
                span(data-bind="click: function () {mode('reg')}, text: $root.i18n('Регистрация')")
        .inputwrap
            span.glyphicon.glyphicon-user
            input.form-control(autocomplete="on", type="text", required="required", placeholder="Enter username or e-mail", name="login", autocorrect="off", autocapitalize="off")
    .form-group(style="margin-bottom:0;")
        dl.dl-horizontal
            dt(data-bind="text: $root.i18n('Пароль:')")
            dd
                span(data-bind="click: function () {mode('recallRequest')}, text: $root.i18n('Восстановить пароль')")
        .inputwrap
            span.glyphicon.glyphicon-lock
            input.form-control(type="password", required="required", placeholder="Enter password", name="pass", data-bind="event: {keypress: pressHandler}")
        .footnote
            span(data-bind="text: $root.i18n('Для безопасной работы на чужом компьютере, используйте приватную вкладку') + ' ('")
            a.lll(href="https://support.google.com/chrome/answer/95464", target="_blank", data-bind="text: $root.i18n('режим инкогнито')")
            | )
    .form-group(style="margin-bottom:20px;")
        .text-warning.caps-warn(data-bind="style: {height: caps() ? '20px' : '0px'}")
            span.glyphicon.glyphicon-warning-sign
            span(data-bind="text: ' ' + $root.i18n('Caps Lock активен')")
        .mess
            div(data-bind="text: msg()")
        .row.btnsAction
            .col-xs-6
                button.btn.btn-primary(type="submit", data-bind="text: $root.i18n('Вход')")
            .col-xs-6.colright
                button.btn.btn-primary(type="button", data-bind="click: formClose, text: $root.i18n('Отмена')")
        .cantLoging
            a(href="", target="_blank", onclick="ga('send', 'event', 'support', 'click', 'support click login'); $(this).attr('href', 'mailto:support@pastvu.com?Subject=%5BНе%20могу%20войти%5D%20' + $(this).parents('form').find('[name=login]').val())", data-bind="text: $root.i18n('Не можете войти?')")
    | </script>

    | <script id="regTpl" type="text/html">
    .head(data-bind="text: $root.i18n('Регистрация')")
    .form-group
        dl.dl-horizontal
            dt(data-bind="text: $root.i18n('Имя пользователя:')")
            dd: span(data-bind="click: function () {mode('login')}, text: $root.i18n('Авторизация')")
        .inputwrap
            span.glyphicon.glyphicon-user
            input.form-control(autocomplete="off", type="text", required="required", placeholder="User", name="login", autocorrect="off", autocapitalize="off")
    .form-group
        dl.dl-horizontal
            dt E-mail:
            dd
        .inputwrap
            span.glyphicon.glyphicon-envelope
            input.form-control(autocomplete="on", type="email", required="required", placeholder="email", name="email", autocorrect="off", autocapitalize="off")
    .form-group
        dl.dl-horizontal
            dt(data-bind="text: $root.i18n('Пароль:')")
            dd
        .inputwrap
            span.glyphicon.glyphicon-lock
            input.form-control(autocomplete="off", type="password", required="required", placeholder="Enter password", name="pass", data-bind="event: {keypress: pressHandler}")
    .form-group
        dl.dl-horizontal
            dt(data-bind="text: $root.i18n('Повторите пароль:')")
            dd
        .inputwrap
            span.glyphicon.glyphicon-lock
            input.form-control(autocomplete="off", type="password", required="required", placeholder="Enter password", name="pass2", data-bind="event: {keypress: pressHandler}")
    .form-group
        .text-warning.caps-warn(data-bind="style: {height: caps() ? '20px' : '0px'}")
            span.glyphicon.glyphicon-warning-sign
            span(data-bind="text: ' ' + $root.i18n('Caps Lock активен')")
        .mess
            div(data-bind="text: msg()")
        .row.btnsAction
            .col-xs-6
                button.btn.btn-primary(type="submit", data-bind="text: $root.i18n('Отправить')")
            .col-xs-6.colright
                button.btn.btn-primary(type="button", data-bind="click: formClose, text: $root.i18n('Отмена')")
        .row.btnsFinish
            .col-xs-12.colcent
                button.btn.btn-primary(type="button", data-bind="click: formClose, text: $root.i18n('Завершить')")
    | </script>

