.foot.fringe(data-bind="with: repository[M!M]")
    .rightSide.hide-text
        a.footElem.strokeAfter(href="mailto:support@pastvu.com", target="_blank", onclick="ga('send', 'event', 'support', 'click', 'support click common');", data-bind="text: $root.i18n('Support: support@pastvu.com')")
        a.footElem.strokeAfter(target="_blank", onclick="ga('send', 'event', 'rules', 'click', 'rules click common');", data-bind="attr: {href: getRulesUrl()}, text: $root.i18n('Rules')")
        .footElem.strokeAfter(data-bind="click: navigateAbout, text: $root.i18n('About')")
        a.footElem.strokeAfter(href="https://github.com/PastVu", target="_blank", onclick="ga('send', 'event', 'github', 'click', 'go to github');")
            span.github
            | &nbsp;GitHub
        .footElem.copyright
            | PastVu&nbsp;
            span.glyphicon.glyphicon-globe
            =  ' 2009 – ' + new Date().getFullYear()
