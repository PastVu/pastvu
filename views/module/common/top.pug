#top(data-bind="with: repository[M!M]")
    .fringe#panel
        a#brand(href='/', data-bind="attr: {title: $root.i18n('PastVu - ретроспектива среды обитания человечества')}")
            img.logo(src="/img/misc/logow.png")
            .name(data-bind="html: pageTitle()")
        #panelTools.hide-text
            //ko if: auth.loggedIn() && !auth.iAm.nophotoupload()
            a#toUpload.labledIco.strokeAfter(href="/photoUpload")
                .glyphicon.glyphicon-cloud-upload
                .text(data-bind="text: $root.i18n('Загрузить фото')")
            // /ko
            a#gallery.labledIco.strokeAfter(href="/ps")
                .glyphicon.glyphicon-th
                .text(data-bind="text: $root.i18n('Галерея')")
            //ko if: auth.loggedIn()
            //ko if: can.adm()
            a#toAdmin.labledIco.strokeAfter(href="/admin", target="_blank")
                .glyphicon.glyphicon-cog
                .text(data-bind="text: $root.i18n('Админ')")
            // /ko
            a#toProfile.labledIco(data-bind="attr:{href: '/u/'+auth.iAm.login()}")
                .ico.fringe(data-bind="style: {backgroundImage: 'url('+profileAvatar()+')'}")
                .text(data-bind="text: profile")
            // /ko
            //ko if: !auth.loggedIn()
            #toRegister.labledIco(data-bind="click: function(data, evt){auth.show('reg')}")
                .ico
                .text(data-bind="text: $root.i18n('Регистрация')")
            #toLogIn.labledIco.strokeBefore.iconAfter(data-bind="click: function(data, evt){auth.show('login')}")
                .text(data-bind="text: $root.i18n('Вход')")
                .ico
            // /ko
            //ko if: auth.loggedIn()
            #toLogOut.labledIco.strokeBefore.iconAfter(data-bind="click: function(data, evt){auth.doLogout()}")
                .text(data-bind="text: $root.i18n('Выход')")
                .ico
            // /ko
            #lang.labledIco.strokeBefore(data-bind="click: langClick")
                .text(data-bind="text: lang().toUpperCase()")
            // ko if: langAltShow()
            #langAlt(data-bind="click: langAltClick")
                .text(data-bind="text: langAlt().toUpperCase()")
            // /ko
    //ko if: msg().length
    #appMsg(data-bind="css: msgCss()"): span(data-bind="text: msg()")
    // /ko
