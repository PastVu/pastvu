.bottomPanel(data-bind="with: repository[M!M]")
    //ko if: news().length > 0
    .news
        .newsHeader(data-bind="text: $root.i18n('Project news')")
        //ko foreach: news
        //ko if: $index()
        hr
        // /ko
        .novel.clearfix
            .newsLeft
                .newsDate(data-bind="text: moment($data.pdate).format('D MMM')")
                //ko if: $data.ccount
                a.newsComms(data-bind="html: $root.intl.num($data.ccount) + ($data.ccount_new ? '<div class=\"cnew\">+' + $root.intl.num($data.ccount_new) + '</div>' : ''), attr: {href: '/news/' + $data.cid + '?hl=comments', title: $root.i18n('Open the news comments')}")
                // /ko
            .newsBody
                a.newsTitle(data-bind="text: $data.title, attr: {href: '/news/' + $data.cid}")
                .newsNotice(data-bind="html: $data.notice")
                //ko if: $data.expand
                a.newsExpand(data-bind="attr: {href: '/news/' + $data.cid}, text: '[' + $root.i18n('Read more..') + ']'")
                // /ko
        // /ko
    // /ko
    nav.navbar.navbar-pastvu.catMenu
        ul.nav.navbar-nav
            //ko foreach: cats
            li(data-bind="css: {loading: $data === $parent.catLoading(), active: $data === $parent.catActive()}, click: $parent.catClickBind")
                a(data-bind="text: $root.i18n($parent.catsObj[$data].name)")
            // /ko
            li
                a(target="_blank", href="/news")
                    span(data-bind="text: $root.i18n('News archive')")
                    span.glyphicon.glyphicon-share
    //ko if: catActive()
    .catContent(data-bind="template: catsObj[catActive()].tpl")
    // /ko

    | <script id="photosTpl" type="text/html">
    .photosNew
        //ko foreach: photos
        .photoPreview.withStatus.withInfo.fringe(data-bind="attr: {title: title}")
            a.photoBox(data-bind="attr: {href: $data.link}")
                img.img(data-bind="attr: {src: sfile, alt: title}, event: {load: $parent.onPreviewLoad, error: $parent.onPreviewErr}")
                .curtain
                //ko if: $data.my
                .status.upper.mine.fringe(data-bind="attr: {title: $root.i18n('This is your photo')}")
                    span.glyphicon.glyphicon-user
                // /ko
            .info
                a.title(data-bind="text: title, attr: {href: $data.link}")
                //ko if: $data.rs
                .regions(data-bind="foreach: $data.rs", title=" ")
                    | <!--ko if: $index()-->, <!-- /ko -->
                    a.shortRegion(data-bind="css: {where: !$data.cid}, attr: {href: '/ps?f='+(!$data.cid ? 'geo!0'+($parent.rs[$index()+1] ? '_r!'+$parent.rs[$index()+1].cid : '') : 'r!'+$data.cid), title: $root.regionTitle($data)}, text: $root.regionTitle($data)")
                // /ko
            //ko if: $data.ccount || $data.changed
            .rightBlocks
                //ko if: $data.ccount
                a.rightBlock.comm(data-bind="html: $root.intl.num($data.ccount) + ($data.ccount_new ? '<span class=\"cnew\"> +' + $root.intl.num($data.ccount_new) + '</span>' : ''), attr: {href: $data.link + '?hl=comments', title: $root.i18n('Comments')}")
                // /ko
                //ko if: $data.changed
                a.rightBlock.changed(data-bind="attr: {href: $data.link + '?history=1', title: $root.i18n('Photo changed since last view')}")
                    span.glyphicon.glyphicon-pencil
                // /ko
            // /ko
        // /ko
        //ko if: moreLink()
        a.photoPreview.withInfo.nextPhoto(data-bind="attr: {href: moreLink()}")
            .nextPhotoTxt
                span.glyphicon.glyphicon-fast-forward
                span(data-bind="text: ' ' + $root.i18n('More..')")
        // /ko
    | </script>

    | <script id="ratingsTpl" type="text/html">
    .row.ratings
        .col-xs-6
            .catHead(data-bind="text: $root.i18n('Photo ranking')")
            .row
                .col-xs-6
                    .catGroupHead(data-bind="text: $root.i18n('By views')")
                    .btn-group.btn-group-sm#pbyview
                        button.btn.btn-primary(data-time="day", data-bind="text: $root.i18n('Day'), click: ratSelect, css: {active: ratings.pbyview.selected() === 'day'}")
                        button.btn.btn-primary(data-time="week", data-bind="text: $root.i18n('Week'), click: ratSelect, css: {active: ratings.pbyview.selected() === 'week'}")
                        button.btn.btn-primary(data-time="all", data-bind="text: $root.i18n('All'), click: ratSelect, css: {active: ratings.pbyview.selected() === 'all'}")
                    //ko template: { name: 'ratingsColumnTpl', foreach: ratings.pbyview[ratings.pbyview.selected()] }
                    // /ko
                .col-xs-6
                    .catGroupHead(data-bind="text: $root.i18n('By comments')")
                    .btn-group.btn-group-sm#pbycomm
                        button.btn.btn-primary(data-time="day", data-bind="text: $root.i18n('Day'), click: ratSelect, css: {active: ratings.pbycomm.selected() === 'day'}")
                        button.btn.btn-primary(data-time="week", data-bind="text: $root.i18n('Week'), click: ratSelect, css: {active: ratings.pbycomm.selected() === 'week'}")
                        button.btn.btn-primary(data-time="all", data-bind="text: $root.i18n('All'), click: ratSelect, css: {active: ratings.pbycomm.selected() === 'all'}")
                    //ko template: { name: 'ratingsColumnTpl', foreach: ratings.pbycomm[ratings.pbycomm.selected()] }
                    // /ko
        .col-xs-6
            .catHead(data-bind="text: $root.i18n('User ranking')")
            .row
                .col-xs-6
                    .catGroupHead(data-bind="text: $root.i18n('By comments')")
                    .btn-group.btn-group-sm#ubycomm
                        button.btn.btn-primary(data-time="day", data-bind="text: $root.i18n('Day'), click: ratSelect, css: {active: ratings.ubycomm.selected() === 'day'}")
                        button.btn.btn-primary(data-time="week", data-bind="text: $root.i18n('Week'), click: ratSelect, css: {active: ratings.ubycomm.selected() === 'week'}")
                        button.btn.btn-primary(data-time="all", data-bind="text: $root.i18n('All'), click: ratSelect, css: {active: ratings.ubycomm.selected() === 'all'}")
                    //ko template: { name: 'ratingsColumnTpl', foreach: ratings.ubycomm[ratings.ubycomm.selected()] }
                    // /ko
                .col-xs-6
                    .catGroupHead(data-bind="text: $root.i18n('By uploads')")
                    .btn-group.btn-group-sm#ubyphoto
                        button.btn.btn-primary(data-time="day", data-bind="text: $root.i18n('Day'), click: ratSelect, css: {active: ratings.ubyphoto.selected() === 'day'}")
                        button.btn.btn-primary(data-time="week", data-bind="text: $root.i18n('Week'), click: ratSelect, css: {active: ratings.ubyphoto.selected() === 'week'}")
                        button.btn.btn-primary(data-time="all", data-bind="text: $root.i18n('All'), click: ratSelect, css: {active: ratings.ubyphoto.selected() === 'all'}")
                    //ko template: { name: 'ratingsColumnTpl', foreach: ratings.ubyphoto[ratings.ubyphoto.selected()] }
                    // /ko
    | </script>

    | <script id="ratingsColumnTpl" type="text/html">
    a.row.ratElem(data-bind="attr: {href: $data.link}")
        .imgLoad
            img.img(data-bind="attr: {src: $data.sfile}", onload="G.imgLoadOk(this)", onerror="G.imgLoadFail(this)")
        .ratName(data-bind="text: $data.title, css: {online: $data.online}")
        .ratAmount(data-bind="text: $data.amount")
    | </script>

    | <script id="statsTpl" type="text/html">
    .stats
        .statsFast
            .onlineStat(data-bind="text: stats.common.onlineTxt")
        .row
            .col-xs-12
                .catHead(data-bind="text: $root.i18n('Whole project')")
                .statrow
                    span(data-bind="text: $root.i18n('Registered users:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.userCount)")
                .statrow
                    span(data-bind="text: $root.i18n('Photo count:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.pallCount) + (auth.loggedIn() ? $root.i18n(', of which {{count, number}} public', {count: stats.all.ppubCount}) : '')")
                .statrow(data-bind="html: $root.i18n('Most photos are dated {{year}} — <b>{{count, number}}</b> in total', {year: stats.all.photoYear.pop.year, count: stats.all.photoYear.pop.count})")
                .statrow
                    span(data-bind="text: $root.i18n('New photos today:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.pdayCount)")
                .statrow
                    span(data-bind="text: $root.i18n('New photos this week:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.pweekCount)")
                .statrow
                    span(data-bind="text: $root.i18n('Comment count:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.callCount) + (auth.loggedIn() ? $root.i18n(', of which {{count, number}} deleted', {count: stats.all.callCount - stats.all.cpubCount}) : '')")
                .statrow
                    span(data-bind="text: $root.i18n('New comments today:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.cdayCount)")
                .statrow
                    span(data-bind="text: $root.i18n('New comments this week:') + ' '")
                    b(data-bind="text: $root.intl.num(stats.all.cweekCount)")
    | </script>