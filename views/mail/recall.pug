include head
p
    | #{t('Для Вашей учетной записи был создан запрос на восстановление пароля на проекте PastVu.', { ns: 'mail' })}
    br
    | #{t('Если Вы не производили таких действий на нашем сайте, то просто проигнорируйте и удалите письмо.', { ns: 'mail' })}
p
    | #{t('Для ввода нового пароля перейдите по следующей ссылке:', { ns: 'mail' })}
    br
    a(href=config.client.origin + '/confirm/' + confirmKey, target='_blank')
        = config.client.host + '/confirm/' + confirmKey
    br
    small #{t('Ссылка действительна {{linkvalid}}, по истечении которых Вам будет необходимо запрашивать смену пароля повторно', { linkvalid: linkvalid, ns: 'mail' })}
