mixin noticeLi(arr, path, isPhoto)
    each val in arr
        - usersLogin = Object.keys(val.brief.users)
        li(style="margin-left: 10px;")
            if isPhoto
                a(href=origin + path + val.cid + '?hl=comment-unread&utm_campaign=notification&utm_source=notify_letter&utm_medium=email', target='_blank')= val.title + ' (#' + val.cid + ')'
            else
                a(href=origin + path + val.cid + '?hl=comment-unread&utm_campaign=notification&utm_source=notify_letter&utm_medium=email', target='_blank')= val.title
            div(style="margin-left: 13px;")
                = val.briefFormat.newest
                if val.briefFormat.unread
                    = ' ' + t('({{unread}} in total)', { unread: val.briefFormat.unread, ns: 'mail' })
            if usersLogin.length > 1
                div(style="margin-left: 13px; margin-bottom: 4px;")
                    | #{t('Authors:', { ns: 'mail' })}
                    each login, index in usersLogin
                        if (index < 6)
                            if (index > 0)
                                | ,
                            = ' ' + val.brief.users[login]
                    if usersLogin.length > 6
                        = ' ' + t('et al.', { ns: 'mail' })
            if usersLogin.length === 1
                div(style="margin-left: 13px; margin-bottom: 4px;")
                    | #{t('Author:', { ns: 'mail' })} #{val.brief.users[usersLogin[0]]}

include head
- var origin = config.client.origin
p #{t('At the time this notification was sent, the threads you are subscribed to had received the following number of comments:', { ns: 'mail' })}
if news.length
    p(style="margin-bottom: 2px;")
        strong #{t('News:', { ns: 'mail' })}
    +noticeLi(news, '/news/', false)
if photos.length
    p(style="margin-bottom: 2px;")
        strong #{t('Photos:', { ns: 'mail' })}
    +noticeLi(photos, '/p/', true)
div(style="border-top: 1px solid #eee; border-bottom: 1px solid #fff; margin-top: 1em;")
    p(style="font-size: smaller; margin-top: 0.5em;")
        != t('You can manage your subscriptions on the subscriptions page:', { ns: 'mail' }) + ' '
        a(href=origin + '/u/' + user.login + '/subscriptions', target='_blank')= config.client.host + '/u/' + user.login + '/subscriptions'
        br
        != t('You can adjust the notification interval or disable notifications on the settings page:', { ns: 'mail' }) + ' '
        a(href=origin + '/u/' + user.login + '/settings', target='_blank')= config.client.host + '/u/' + user.login + '/settings'
