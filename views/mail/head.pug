table(style="width: 100%; margin-top: 0px; background-color: #214A78; color: #F2F2F2; border-width: 0px;", border="0", cellspacing="0", cellpadding="0")
    tbody
        tr
            td(style="width: 47px; padding-left: 2px; padding-right: 5px;")
                img(src=config.client.origin + '/img/misc/logo2.png', style="width: 47px; height: 49px; vertical-align: middle; border-image-width: 0; border-width: 0px;")
            td(style="line-height: 1.4em;")
                span(style="vertical-align: middle;")
                    | #{t('Hello, {{username}}!', { username: username, ns: 'mail' })}
                    if greeting
                        br
                        = greeting